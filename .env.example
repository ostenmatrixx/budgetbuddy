# Build-only Sentry credentials. Configure these in CI/Vercel; never expose them as VITE_*.
SENTRY_AUTH_TOKEN=your-private-source-map-upload-token
SENTRY_ORG=your-sentry-organization
SENTRY_PROJECT=your-sentry-project
