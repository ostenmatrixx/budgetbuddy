{
  "name": "budget-tracker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "icons:subset": "bash scripts/subset-material-symbols.sh",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:db": "supabase test db supabase/tests",
    "test:e2e": "playwright test",
    "check": "npm run format:check && npm run lint && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "@fontsource/inter": "^5.3.0",
    "@sentry/react": "^10.0.0",
    "@supabase/supabase-js": "^2.106.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.55.0",
    "@sentry/vite-plugin": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/coverage-v8": "^3.2.7",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.0.0",
    "jsdom": "^29.1.1",
    "material-symbols": "^0.45.8",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "supabase": "2.109.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.3.6",
    "vitest": "^3.2.7"
  }
}
